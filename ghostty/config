# Theme & Visuals (Modern & Borderless)

theme = Ayu Mirage
font-family = "DankMono Nerd Font"
font-family-italic = "DankMono Nerd Font"
font-size = 16
adjust-cell-height = 50%

# Hide OS borders and use a slick tabs layout
macos-titlebar-style = tabs
window-decoration = false

# Semi transparancy with native background blur
background-opacity = 0.90
background-blur = true
window-padding-x = 12
window-padding-y = 8,2
window-padding-balance = true

# power user keybinds
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

#Move focus between splits using Option/Alt + Arrow keys

keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom

#Native tabs controls

keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = shift+command+[=previous_tab
keybind = shift+command+]=next_tab

#dropdown / scratchpad terminal (press ctrl+to toggle anywhere)
keybind = global:ctrl+grave_accent=toggle_quick_terminal

#core performance & advanced utilities
#cursor customization

cursor-style = block
cursor-style-blink = false

#terminal utilities and integration features
shell-integration = detect
shell-integration-features = cursor,sudo,no-title
cursor-click-to-move = true
clipboard-read = allow
clipboard-write = allow
copy-on-select = true

#scrolling: precision trackpad, discrete mouse wheel
mouse-scroll-multiplier = precision:0.5,discrete:1
#experimental shaders (uncomment if you want a custom retro/glitch look)
custom-shader = "shaders/cursor smear.glsl"
